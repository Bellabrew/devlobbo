# Cloudflare Pages: controle de cache
# Este arquivo instrui o Cloudflare a NUNCA servir uma versão antiga
# em cache das páginas HTML — sempre revalida com a origem antes de
# mostrar a página, garantindo que toda atualização apareça imediatamente.

/*
  Cache-Control: no-cache, no-store, must-revalidate

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/blog/*
  Cache-Control: no-cache, no-store, must-revalidate

/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/srplantao/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Arquivos com hash no nome (JS/CSS versionados) podem cachear por mais
# tempo com segurança, já que qualquer mudança gera um nome novo.
/srplantao/assets/*
  Cache-Control: public, max-age=31536000, immutable
